{
  "name": "@catalog/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "esbuild src/handlers/api.ts --bundle --platform=node --target=node22 --outdir=dist --format=esm --packages=external",
    "dev": "tsx src/local-server.ts"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1090.0",
    "@aws-sdk/client-s3": "^3.1090.0",
    "@aws-sdk/lib-dynamodb": "^3.1090.0",
    "@aws-sdk/s3-request-presigner": "^3.1090.0",
    "@catalog/application": "*",
    "@catalog/domain": "*",
    "@catalog/shared": "*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.162",
    "@types/node": "^24.13.2",
    "esbuild": "^0.28.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  }
}
